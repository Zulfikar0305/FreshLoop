rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ────────────────────────────────────────────────────────────
    // Each user can only read or write their own profile document.
    match /users/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // ── Inventory Items ──────────────────────────────────────────────────
    // Users can only access items they own (userId field must match uid).
    match /inventoryItems/{itemId} {
      allow read, update, delete: if request.auth != null
                                  && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
    }

    // ── Waste Logs ───────────────────────────────────────────────────────
    // Users can read their own logs and create new ones.
    // No client-side update or delete is required.
    match /wasteLogs/{logId} {
      allow read: if request.auth != null
                  && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
    }

    // ── Donations ────────────────────────────────────────────────────────
    // Any authenticated user can read all donations (coordinators need to
    // see all available listings).
    // Only the creator can create (userId must match their uid).
    // Any authenticated user can update status (claim / confirm pickup).
    // Only the original creator can delete their own donation.
    match /donations/{donationId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null;
      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;
    }

    // ── Reports ──────────────────────────────────────────────────────────
    // Authenticated users can submit reports.
    // No client-side read is required (reviewed via Firebase console/admin).
    match /reports/{reportId} {
      allow create: if request.auth != null;
    }
  }
}
