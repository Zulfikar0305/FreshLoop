rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Inventory Images ─────────────────────────────────────────────────
    // Authenticated users can upload and read only their own images.
    // Path: inventoryImages/{userId}/{filename}
    match /inventoryImages/{userId}/{filename} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }

    // All other Storage paths are denied by default.
  }
}
